{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "thisisnotadraft.com" }],
      "destination": "https://happyjack.media/tinad/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.thisisnotadraft.com" }],
      "destination": "https://happyjack.media/tinad/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "jackblair.net" }],
      "destination": "https://happyjack.media/jack-blair/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.jackblair.net" }],
      "destination": "https://happyjack.media/jack-blair/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/bow",
      "destination": "https://beards-of-war-bow.vercel.app/bow"
    },
    {
      "source": "/bow/:path*",
      "destination": "https://beards-of-war-bow.vercel.app/bow/:path*"
    }
  ]
}
